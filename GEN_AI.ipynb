    {
      "cell_type": "code",
      "source": [
        "\n",
        "\n",
        "import tensorflow as tf\n",
        "from tensorflow.keras.layers import Input, LSTM, Dense, Embedding, Dot, Activation, Concatenate\n",
        "import numpy as np\n",
        "\n",
        "print(\"=\" * 60)\n",
        "print(\" Attention-based Encoder-Decoder Model\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "# Simple training data (English -> Spanish)\n",
        "en_sentences = [\"hello\", \"good morning\", \"thank you\", \"goodbye\"]\n",
        "es_sentences = [\"hola\", \"buenos días\", \"gracias\", \"adiós\"]\n",
        "\n",
        "print(\"\\nTraining Data:\")\n",
        "for en, es in zip(en_sentences, es_sentences):\n",
        "    print(f\"  {en} → {es}\")\n",
        "\n",
        "# Simplified Attention Mechanism (Conceptual)\n",
        "class AttentionLayer(tf.keras.layers.Layer):\n",
        "    def __init__(self, units):\n",
        "        super().__init__()\n",
        "        self.W1 = Dense(units)\n",
        "        self.W2 = Dense(units)\n",
        "        self.V = Dense(1)\n",
        "\n",
        "    def call(self, query, values):\n",
        "        # query: decoder hidden state, values: encoder outputs\n",
        "        # Additive (Bahdanau) attention\n",
        "        query_with_time = tf.expand_dims(query, 1)\n",
        "        score = self.V(tf.nn.tanh(self.W1(query_with_time) + self.W2(values)))\n",
        "        attention_weights = tf.nn.softmax(score, axis=1)\n",
        "        context = attention_weights * values\n",
        "        context = tf.reduce_sum(context, axis=1)\n",
        "        return context, attention_weights\n",
        "\n",
        "print(\"\\n--- MODEL ARCHITECTURE ---\")\n",
        "print(\"Components:\")\n",
        "print(\"  1. Encoder: Embedding + LSTM\")\n",
        "print(\"  2. Attention: Bahdanau Attention Mechanism\")\n",
        "print(\"  3. Decoder: LSTM + Dense (with attention context)\")\n",
        "print(\"\\nKey Innovation: Attention allows decoder to focus on\")\n",
        "print(\"relevant encoder states dynamically for each output token.\")\n",
        "\n",
        "# Architecture demonstration\n",
        "vocab_size = 100\n",
        "embedding_dim = 64\n",
        "latent_dim = 128\n",
        "\n",
        "print(f\"\\nHyperparameters:\")\n",
        "print(f\"  Vocabulary Size: {vocab_size}\")\n",
        "print(f\"  Embedding Dimension: {embedding_dim}\")\n",
        "print(f\"  Hidden/Latent Dimension: {latent_dim}\")\n",
        "\n",
        "# Create simplified model components\n",
        "encoder_embedding = Embedding(vocab_size, embedding_dim)\n",
        "encoder_lstm = LSTM(latent_dim, return_sequences=True, return_state=True)\n",
        "\n",
        "attention = AttentionLayer(latent_dim)\n",
        "\n",
        "decoder_embedding = Embedding(vocab_size, embedding_dim)\n",
        "decoder_lstm = LSTM(latent_dim, return_sequences=True, return_state=True)\n",
        "output_dense = Dense(vocab_size, activation='softmax')\n",
        "\n",
        "print(\"\\nModel components created successfully!\")\n",
        "print(\"\\nTraining Process (Conceptual):\")\n",
        "print(\"  1. Encode source sentence (English)\")\n",
        "print(\"  2. At each decoding step:\")\n",
        "print(\"     - Calculate attention weights over encoder outputs\")\n",
        "print(\"     - Generate context vector as weighted sum\")\n",
        "print(\"     - Combine context with decoder state\")\n",
        "print(\"     - Predict next Spanish word\")\n",
        "print(\"  3. Teacher forcing during training\")\n",
        "print(\"  4. Beam search during inference\")\n",
        "\n",
        "print(\"\\n--- ATTENTION MECHANISM BENEFITS ---\")\n",
        "print(\"✓ Dynamic alignment between source and target words\")\n",
        "print(\"✓ Better handling of long sequences\")\n",
        "print(\"✓ Improved translation quality (BLEU +2-3 points)\")\n",
        "print(\"✓ Interpretable attention weights\")\n",
        "\n",
        "print(\"\\n\" + \"=\"*60)\n",
        "print(\"Attention-based model architecture demonstrated!\")\n",
        "print(\"For full training, use parallel corpora like Tatoeba or WMT.\")\n",
        "print(\"=\"*60)"
      ],
